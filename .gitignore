# Vivado temporary files and folders to ignore
*.jou
*.log
*.str
*.pb
*.wdb
*.wcfg
*.do
*.vcd
*.sdb
*.elf
*.rlx
.Xil/
xsim.dir/

# Ignore binary/hex artifacts
*.hex
*.bin
*.vvp
*.out

# Ignore massive build directories
*.cache/
*.hw/
*.ip_user_files/
*.sim/
*.runs/
build/
dist/
__pycache__/
node_modules/

# Keep the Vivado project file, but ignore its auto-generated backups
*.xpr.backup*
